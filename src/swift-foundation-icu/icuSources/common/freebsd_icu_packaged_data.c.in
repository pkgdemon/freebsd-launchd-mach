/*
 * freebsd-launchd-mach (2026-05-15)
 *
 * Replacement for upstream icu_packaged_data.cpp (a giant uint8_t[]
 * = { ...40M hex literals... } that peaks at 6-10 GB resident in
 * clang's parser, infeasible on the project's 8 GB CI VM per the
 * build-on-low-end-systems rule).
 *
 * Strategy: ship the same bytes via the assembler's .incbin, which
 * reads a binary file directly into the .o data section with no
 * AST overhead. Compile peak: ~150 MB.
 *
 * Implementation: a top-level __asm__ block in this .c file. We
 * use a .c with inline asm rather than a standalone .S because
 * CMake's per-source-file LANGUAGE override (set_source_files_
 * properties LANGUAGE C on a .S) didn't apply across the
 * directory scope from icuSources/common to the _FoundationICU
 * target defined in icuSources/CMakeLists.txt -- the file was
 * silently dropped from the compile list in iteration #10.
 * A real .c file always builds.
 *
 * Symbol name: U_ICUDATA_ENTRY_POINT in utypes.h is a macro that
 * expands to icudt<MAJOR>_dat at compile time. CMake extracts
 * U_ICU_VERSION_MAJOR_NUM from uvernum.h and substitutes the
 * literal symbol name via @ICU_DATA_SYMBOL@ at configure time.
 *
 * Portable across all ELF targets (x86_64, aarch64, riscv64).
 * Not portable to Mach-O / COFF, out of scope.
 */

__asm__(
	".section .rodata\n"
	".balign 8\n"
	".globl @ICU_DATA_SYMBOL@\n"
	".type @ICU_DATA_SYMBOL@, %object\n"
	"@ICU_DATA_SYMBOL@:\n"
	".incbin \"@ICU_PACKAGED_BIN_PATH@\"\n"
	".L_freebsd_icu_packaged_data_end:\n"
	".size @ICU_DATA_SYMBOL@, .L_freebsd_icu_packaged_data_end - @ICU_DATA_SYMBOL@\n"
);
