#!/bin/sh
# launchd-getty-wrapper — defensive getty launcher for KeepAlive plists.
#
# Why this exists: launchd plists with KeepAlive=true respawn the
# command the moment it exits. If the underlying tty device doesn't
# exist on a particular hardware (e.g., /dev/ttyu0 on a machine with
# no UART, or /dev/ttyv0 on a serial-only qemu boot), bare `getty`
# fails to open it and exits immediately — and launchd hammers the
# respawn at full CPU.
#
# This wrapper checks the device first. If absent, sleep for a long
# while so the respawn rate stays at "once per day" instead of
# thousands per second. If present, exec the real getty so launchd
# tracks the right pid.
#
# Usage:
#   launchd-getty-wrapper <gettytab-type> <tty-device>
# Example:
#   launchd-getty-wrapper 3wire ttyu0       # serial
#   launchd-getty-wrapper Pc    ttyv0       # PC keyboard / VGA
#
# Ported verbatim from sibling sockets-version freebsd-launchd repo
# (overlays/usr/libexec/launchd-getty-wrapper), where this exact
# shape was proven to boot to login under launchd-as-PID-1.

set -eu

if [ $# -ne 2 ]; then
	echo "usage: $0 <gettytab-type> <tty-device>" >&2
	exit 64
fi

GETTYTAB_TYPE="$1"
TTY_DEVICE="$2"

if [ ! -c "/dev/$TTY_DEVICE" ]; then
	echo "launchd-getty-wrapper: /dev/$TTY_DEVICE not present on this hardware; sleeping" >&2
	# 24 hours. launchd's KeepAlive will respawn after we exit, but
	# at this rate it's irrelevant. Operator can flip the plist with
	# launchctl unload to avoid even that respawn cycle.
	sleep 86400
	exit 0
fi

exec /usr/libexec/getty "$GETTYTAB_TYPE" "$TTY_DEVICE"
